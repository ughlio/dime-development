# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit secrets.

# Get a free API key at https://resend.com (signup, then Settings → API Keys)
RESEND_API_KEY=

# Coach's email address — booking/contact form submissions are sent here
COACH_EMAIL=coach@dimedevelopment.com

# Optional: override the "From" address used by Resend.
# Default is "Dime Development <onboarding@resend.dev>" (Resend's test sender).
# To send from a real address, verify your domain in Resend and set e.g.:
# RESEND_FROM=Dime Development <hello@dimedevelopment.com>
RESEND_FROM=
